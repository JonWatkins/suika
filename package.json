{
  "name": "suika",
  "version": "1.3.7",
  "description": "Suika is a lightweight component based Javascript library for building user interfaces",
  "homepage": "https://jonwatkins.github.io/suika/",
  "author": "Jon Watkins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonWatkins/suika.git"
  },
  "bugs": {
    "url": "https://github.com/JonWatkins/suika/issues"
  },
  "main": "dist/bundle.umd.js",
  "browser": "dist/bundle.umd.js",
  "module": "dist/bundle.esm.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "lint:format": "prettier  --loglevel warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\" ",
    "lint:fix": "eslint ./src --ext .jsx,.js,.ts,.tsx --quiet --fix",
    "lint": "npm run lint:format && npm run lint:fix ",
    "test": "jest",
    "production": "cross-env NODE_ENV=production rollup -c",
    "build": "npm run lint && npm run test && npm run production"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-typescript": "^7.21.4",
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "babel-jest": "^29.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "prettier": "^2.8.7",
    "rollup": "^2.79.1",
    "rollup-plugin-terser": "^7.0.2"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "suika",
    "vdom",
    "JSX",
    "reactive"
  ]
}
