{
  "private": true,
  "version": "1.5.4",
  "type": "module",
  "scripts": {
    "format": "prettier  --loglevel warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\" ",
    "lint": "eslint . --ext .jsx,.js,.ts,.tsx --quiet --fix && pnpm run format",
    "build": "cross-env NODE_ENV=production node ./scripts/build.js",
    "dev": "pnpm --filter \"suika-test\" run dev",
    "preinstall": "node ./scripts/preinstall.js",
    "postinstall": "node ./scripts/setup.js",
    "docs": "node ./scripts/docs.js",
    "ci": "pnpm run build && pnpm test",
    "test": "pnpm run lint && jest"
  },
  "devDependencies": {
    "@babel/core": "^7.21.5",
    "@babel/preset-env": "^7.21.5",
    "@babel/preset-typescript": "^7.21.5",
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-node-resolve": "^15.0.2",
    "@rollup/plugin-terser": "^0.4.1",
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.1",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "babel-jest": "^29.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.39.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "execa": "^7.1.1",
    "gh-pages": "^5.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "minimist": "^1.2.8",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.0",
    "rollup": "^3.21.2",
    "rollup-plugin-dts": "^5.3.0",
    "rollup-plugin-scss": "^4.0.0",
    "rollup-plugin-serve": "^2.0.2",
    "sass": "^1.62.1",
    "suika-docs-theme": "^1.0.7",
    "ts-node": "^10.9.1",
    "tslib": "^2.5.0",
    "typedoc": "^0.24.6",
    "typescript": "^4.9.5"
  },
  "workspaces": [
    "packages/suika",
    "packages/suika-ui",
    "packages/suika-router"
  ]
}
